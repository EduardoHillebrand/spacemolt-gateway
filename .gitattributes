# Normalize line endings: checkout as-is on Windows, LF in the repo.
* text=auto

# Force LF for files that must never have CRLF.
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Binaries — never touch.
*.png binary
*.jpg binary
*.ico binary
